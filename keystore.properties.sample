## Copy to keystore.properties and fill in. That file is gitignored — never commit it.
## Create the keystore with:
##   keytool -genkey -v -keystore tune-release.jks -alias tune \
##           -keyalg RSA -keysize 4096 -validity 10000
storeFile=tune-release.jks
storePassword=
keyAlias=tune
keyPassword=
